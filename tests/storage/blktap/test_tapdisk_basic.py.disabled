@pytest.mark.no_vm
class TestTapdiskErrors:
    """Test error handling."""

    def test_open_nonexistent_file(self, tapctl):
        """Opening non-existent file should fail."""
        pid = tapctl.spawn()
        minor, _ = tapctl.allocate()
        tapctl.attach(pid, minor)

        try:
            # Try to open non-existent file
            with pytest.raises(TapCtlError):
                tapctl.open(pid, minor, "vhd:/nonexistent/file.vhd")

        finally:
            # Cleanup
            try:
                tapctl.detach(pid, minor)
                tapctl.free(minor)
            except Exception:
                pass

    def test_double_open_fails(self, tapctl, test_vhd_small):
        """Opening same VBD twice should fail."""
        pid = tapctl.spawn()
        minor, _ = tapctl.allocate()
        tapctl.attach(pid, minor)

        image_path = f"vhd:{test_vhd_small}"

        try:
            tapctl.open(pid, minor, image_path)

            # Try to open again
            with pytest.raises(TapCtlError):
                tapctl.open(pid, minor, image_path)

        finally:
            # Cleanup
            try:
                tapctl.close(pid, minor)
                tapctl.detach(pid, minor)
                tapctl.free(minor)
            except Exception:
                pass

    def test_detach_without_close_fails(self, tapctl, test_vhd_small):
        """Detaching without closing should fail."""
        image_path = f"vhd:{test_vhd_small}"
        pid, minor = tapctl.create(image_path)

        try:
            # Try to detach without closing - should fail
            with pytest.raises(TapCtlError):
                tapctl.detach(pid, minor)

        finally:
            # Cleanup - use force destroy
            try:
                tapctl.destroy(pid, minor)
            except Exception as e:
                # If destroy fails, try force close first
                try:
                    tapctl.close(pid, minor, force=True)
                    tapctl.detach(pid, minor)
                    tapctl.free(minor)
                except Exception:
                    # Give up, process might be dead
                    pass
