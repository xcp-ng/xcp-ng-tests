{
  "$defs": {
    "GuestToolsConfig": {
      "properties": {
        "download_url": {
          "title": "Download Url",
          "type": "string"
        },
        "win": {
          "additionalProperties": {
            "additionalProperties": true,
            "type": "object"
          },
          "title": "Win",
          "type": "object"
        },
        "other": {
          "additionalProperties": true,
          "title": "Other",
          "type": "object"
        },
        "installed": {
          "additionalProperties": {
            "additionalProperties": true,
            "type": "object"
          },
          "title": "Installed",
          "type": "object"
        }
      },
      "required": [
        "download_url"
      ],
      "title": "GuestToolsConfig",
      "type": "object"
    },
    "HostConfig": {
      "properties": {
        "default_user": {
          "title": "Default User",
          "type": "string"
        },
        "default_password": {
          "title": "Default Password",
          "type": "string"
        },
        "default_password_hash": {
          "default": "",
          "title": "Default Password Hash",
          "type": "string"
        }
      },
      "required": [
        "default_user",
        "default_password"
      ],
      "title": "HostConfig",
      "type": "object"
    },
    "InstallConfig": {
      "properties": {
        "answerfiles": {
          "additionalProperties": true,
          "title": "Answerfiles",
          "type": "object"
        },
        "isos": {
          "$ref": "#/$defs/InstallIsosConfig"
        },
        "iso_remaster": {
          "default": "",
          "title": "Iso Remaster",
          "type": "string"
        }
      },
      "required": [
        "isos"
      ],
      "title": "InstallConfig",
      "type": "object"
    },
    "InstallIsosConfig": {
      "properties": {
        "base_url": {
          "title": "Base Url",
          "type": "string"
        },
        "cache_dir": {
          "title": "Cache Dir",
          "type": "string"
        },
        "definitions": {
          "additionalProperties": {
