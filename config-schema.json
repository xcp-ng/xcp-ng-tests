      "type": "object"
    },
    "LintstorConfig": {
      "properties": {
        "redundancy": {
          "default": 2,
          "title": "Redundancy",
          "type": "integer"
        }
      },
      "title": "LintstorConfig",
      "type": "object"
    },
    "NetworkConfig": {
      "properties": {
        "mgmt": {
          "default": "Pool-wide network associated with eth0",
          "title": "Mgmt",
          "type": "string"
        },
        "free_nics": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Free Nics",
          "type": "array"
        }
      },
      "title": "NetworkConfig",
      "type": "object"
    },
    "PXEConfig": {
      "properties": {
