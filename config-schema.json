        "cephfs": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Cephfs",
          "type": "object"
        },
        "moosefs": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Moosefs",
          "type": "object"
        },
        "lvmohba": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Lvmohba",
          "type": "object"
        },
        "lvmoiscsi": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Lvmoiscsi",
          "type": "object"
        },
        "linstor": {
          "$ref": "#/$defs/LintstorConfig"
        }
      },
      "title": "StorageConfig",
      "type": "object"
    },
    "VMConfig": {
      "properties": {
        "def_url": {
          "title": "Def Url",
          "type": "string"
        },
        "cache_imported": {
          "title": "Cache Imported",
          "type": "boolean"
        },
        "default_sr": {
          "title": "Default Sr",
          "type": "string"
        },
        "images": {
          "$ref": "#/$defs/VMImagesConfig"
        },
        "equivalents": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Equivalents",
          "type": "object"
        }
