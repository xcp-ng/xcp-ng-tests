        "cache_imported",
        "default_sr"
      ],
      "title": "VMConfig",
      "type": "object"
    },
    "VMImagesConfig": {
      "additionalProperties": true,
      "properties": {},
      "title": "VMImagesConfig",
      "type": "object"
    }
  },
  "properties": {
    "objects_name_prefix": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Objects Name Prefix"
    },
    "dns_server": {
      "default": "1.1.1.1",
      "title": "Dns Server",
      "type": "string"
    },
    "host": {
      "$ref": "#/$defs/HostConfig"
    },
    "hosts": {
      "additionalProperties": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Hosts",
      "type": "object"
    },
    "network": {
      "$ref": "#/$defs/NetworkConfig"
    },
    "pxe": {
      "$ref": "#/$defs/PXEConfig"
    },
    "vm": {
      "$ref": "#/$defs/VMConfig"
    },
    "install": {
      "$ref": "#/$defs/InstallConfig"
    },
    "guest_tools": {
      "$ref": "#/$defs/GuestToolsConfig"
    },
    "ssh": {
      "$ref": "#/$defs/SSHConfig"
    },
    "storage": {
      "$ref": "#/$defs/StorageConfig"
    },
    "volume_size": {
      "title": "Volume Size",
      "type": ["string", "integer"],
      "description": "Default size of VDIs created for storage tests. Accepts sizes like '1 GiB', '2.5TiB', or plain integers."
    },
    "write_volume_cap": {
      "title": "Write Volume Cap",
      "type": ["string", "integer"],
      "description": "Maximum amount of data written to a volume during storage tests. Accepts sizes like '2 GiB' or '500MiB'."
    },
    "write_volume_align": {
      "title": "Write Volume Align",
      "type": "integer"
    }
  },
  "required": [
    "host",
    "pxe",
    "vm",
    "install",
    "guest_tools",
    "ssh",
    "volume_size",
    "write_volume_cap",
    "write_volume_align"
  ],
  "title": "XCP-ng Tests Configuration Schema",
  "type": "object",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "JSON Schema for validating config.toml, config.default.toml, and config.NAME.toml files"
}
