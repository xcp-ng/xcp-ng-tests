      "required": [
        "config_server",
        "arp_server"
      ],
      "title": "PXEConfig",
      "type": "object"
    },
    "SSHConfig": {
      "properties": {
        "pubkey": {
          "title": "Pubkey",
          "type": "string"
        },
        "output_max_lines": {
          "default": 20,
          "title": "Output Max Lines",
          "type": "integer"
        },
        "ignore_banner": {
          "default": false,
          "title": "Ignore Banner",
          "type": "boolean"
        }
      },
      "required": [
        "pubkey"
      ],
      "title": "SSHConfig",
      "type": "object"
    },
    "StorageConfig": {
      "properties": {
        "nfs": {
          "additionalProperties": {
            "type": "string"
          },
